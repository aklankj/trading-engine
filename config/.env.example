# ═══════════════════════════════════════════════════════════
# TRADING ENGINE — Environment Configuration
# Copy this to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════

# Zerodha Kite Connect
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# OpenRouter (for research scanner + Claude analysis)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Capital & Risk
INITIAL_CAPITAL=100000
MAX_POSITION_PCT=0.05
MAX_DAILY_LOSS_PCT=0.02
MAX_OPEN_POSITIONS=10
MAX_SECTOR_EXPOSURE_PCT=0.30
FUNDAMENTAL_ALLOCATION_PCT=0.60
ACTIVE_ALLOCATION_PCT=0.30
CASH_RESERVE_PCT=0.10

# Paths
DATA_DIR=./data
LOG_DIR=./logs
TRADE_LOG=./data/trade_log.json
PAPER_LOG=./data/paper_log.json
SIGNAL_LOG=./data/signal_log.csv

# Mode: paper | approval | semi_auto
TRADING_MODE=paper
